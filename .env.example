# ============================================
# My Pain Clinic Global - WhatsApp AI Assistant
# Environment Variables
# ============================================

# Groq API Key
GROQ_API_KEY=your-groq-api-key

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your-whatsapp-access-token
PHONE_NUMBER_ID=your-phone-number-id
VERIFY_TOKEN=your-custom-webhook-verify-token

# Database (PostgreSQL - Supabase)
# Note: Copy the 'Transaction' connection string from Supabase Settings > Database
# IMPORTANT: Replace 'postgresql://' with 'postgresql+asyncpg://' at the start of the URL
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-ID].supabase.co:5432/postgres

# Redis (Cloud)
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@day-milk-brumal-28908.db.redis.io:14894

# Clinic Staff Phone (for escalation notifications, with country code)
CLINIC_STAFF_PHONE=919876543210

# Admin API Key (for appointment management endpoints)
ADMIN_API_KEY=your-secure-admin-api-key

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Redis Agent Memory Services
REDIS_MEMORY_ENDPOINT=https://gcp-us-east4.memory.redis.io
REDIS_MEMORY_STORE_ID=your-redis-memory-store-id
REDIS_MEMORY_API_KEY=your-redis-memory-api-key

# Redis LangCache Semantic Caching Services
REDIS_LANGCACHE_ENDPOINT=https://aws-ap-south-1.langcache.redis.io
REDIS_LANGCACHE_CACHE_ID=your-redis-langcache-cache-id
REDIS_LANGCACHE_API_KEY=your-redis-langcache-api-key




